MIN_EDGE_BPS=50
SCAN_INTERVAL_MS=10000
MAX_SPREAD_CENTS=20
MIN_HALT_BUFFER_MINUTES=2

# Execution mode defaults to paper. Live mode requires both EXECUTION_MODE=live
# and ENABLE_LIVE_TRADING=true.
EXECUTION_MODE=paper
ENABLE_LIVE_TRADING=false
PAYER_MNEMONIC=
ALGOD_URL=https://mainnet-api.algonode.cloud
ORDER_QUANTITY=1
MIN_PRICE_CENTS=2
MAX_PRICE_CENTS=98
MAX_ACTIVE_ORDERS=2
MAX_USDCA_AT_RISK_CENTS=100
TICK_INTERVAL_MS=60000
MOVE_SCORE_DELTA_PCT=12
MIN_DWELL_SECONDS=180
MAX_MOVES_PER_HOUR=8
HALT_BLOCK_MINUTES=6
BOT_STATE_PATH=state/bot-state.json

# Required for Alpha bot state persistence.
DATABASE_URL=postgresql://postgres.example:[YOUR-PASSWORD]@aws-1-eu-north-1.pooler.supabase.com:6543/postgres
ALPHA_STATE_KEY=alpha

# Cron runner settings for cloud worker deployment.
ALPHA_CRON_SCHEDULE=*/2 * * * *
ALPHA_CRON_COMMAND=npm run alpha:live
ALPHA_ENABLE_LIVE_TRADING=true
ALPHA_CONFIRM_RISK=true
ALPHA_WALLET_ADDRESS=
ALPHA_MAX_ORDER_SIZE_USD=1
ALPHA_MAX_MARKET_EXPOSURE_USD=3
ALPHA_MAX_TOTAL_EXPOSURE_USD=10
ALPHA_MAX_LIVE_OPEN_ORDERS=4
