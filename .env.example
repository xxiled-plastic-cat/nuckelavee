MIN_EDGE_BPS=50
SCAN_INTERVAL_MS=10000
MAX_SPREAD_CENTS=20
MIN_HALT_BUFFER_MINUTES=2

# Execution mode defaults to paper. Live mode requires both EXECUTION_MODE=live
# and ENABLE_LIVE_TRADING=true.
EXECUTION_MODE=paper
ENABLE_LIVE_TRADING=false
PAYER_MNEMONIC=
ALGOD_URL=https://mainnet-api.algonode.cloud
ORDER_QUANTITY=1
MIN_PRICE_CENTS=2
MAX_PRICE_CENTS=98
MAX_ACTIVE_ORDERS=2
MAX_USDCA_AT_RISK_CENTS=100
TICK_INTERVAL_MS=60000
MOVE_SCORE_DELTA_PCT=12
MIN_DWELL_SECONDS=180
MAX_MOVES_PER_HOUR=8
HALT_BLOCK_MINUTES=6
BOT_STATE_PATH=state/bot-state.json

# Required for Alpha bot state persistence.
DATABASE_URL=postgresql://postgres.example:[YOUR-PASSWORD]@aws-1-eu-north-1.pooler.supabase.com:6543/postgres
ALPHA_STATE_KEY=alpha

# Cron runner settings for cloud worker deployment.
ALPHA_CRON_SCHEDULE=*/2 * * * *
ALPHA_CRON_COMMAND=npm run alpha:live
# DigitalOcean Web Services set PORT automatically for readiness probes.
# Set ALPHA_HEALTH_PORT locally only if you want to test the health server.
ALPHA_HEALTH_PORT=8080
ALPHA_ENABLE_LIVE_TRADING=true
ALPHA_CONFIRM_RISK=true
ALPHA_WALLET_ADDRESS=
ALPHA_TARGET_QUOTE_SIZE_USD=3
ALPHA_MAX_ORDER_SIZE_USD=3
ALPHA_MAX_MARKET_EXPOSURE_USD=6
ALPHA_MAX_TOTAL_EXPOSURE_USD=12
ALPHA_MAX_LIVE_OPEN_ORDERS=6
ALPHA_MAX_LIVE_ORDERS_PER_MARKET=2
ALPHA_QUOTE_REFRESH_THRESHOLD_CENTS=1
ALPHA_MIN_ALGO_BALANCE=3
ALPHA_REWARD_MIN_DWELL_SECONDS=180
ALPHA_ENABLE_PARITY_ARB=false
ALPHA_PARITY_MIN_EDGE_BPS=150
ALPHA_PARITY_MAX_TRADE_USD=1
ALPHA_PARITY_MAX_DAILY_USD=3
ALPHA_PARITY_SLIPPAGE_CENTS=0.25
ALPHA_PARITY_MIN_DEPTH_USD=1
ALPHA_PARITY_REQUIRE_IMMEDIATE_MERGE=true
ALPHA_ENABLE_SPREAD_CAPTURE=true
ALPHA_SPREAD_SCAN_ORDERBOOK_LIMIT=75
ALPHA_SPREAD_ORDER_SIZE_USD=1
ALPHA_MIN_SPREAD_CAPTURE_CENTS=1
ALPHA_MIN_SPREAD_VOLUME_USD=1
ALPHA_MIN_SPREAD_DEPTH_USD=0.25
ALPHA_SPREAD_PERSISTENCE_SCANS=2
ALPHA_SPREAD_EXIT_SLOT_RESERVE=2
ALPHA_MIN_SPREAD_ENTRY_MIDPOINT=0.05
ALPHA_MIN_SPREAD_EXIT_MIDPOINT=0.01
ALPHA_SPREAD_ENTRY_MIN_DWELL_SECONDS=600
ALPHA_SPREAD_EXIT_EDGE_CENTS=1
ALPHA_SPREAD_EXIT_MIN_DWELL_SECONDS=1800
ALPHA_MAX_SPREAD_MIDPOINT=0.97
ALPHA_MAX_SPREAD_MARKET_EXPOSURE_USD=2
